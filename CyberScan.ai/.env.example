# ═══════════════════════════════════════════════════════════════════════════════
#  SecureScout — Environment Variables
#  Copy this file to .env and fill in real values before running.
#  NEVER commit .env to version control!
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development       # development | production
DEBUG=false

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=securescout_strong_password_here

# These are auto-constructed from POSTGRES_PASSWORD in docker-compose.yml
# For local (non-Docker) development, set them explicitly:
DATABASE_URL=postgresql+asyncpg://securescout:securescout_strong_password_here@localhost:5432/securescout
DATABASE_URL_SYNC=postgresql://securescout:securescout_strong_password_here@localhost:5432/securescout

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OpenAI (AI Report Generation) ────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo    # or gpt-4o-mini for better quality

# ── Razorpay (Payments) ───────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret-key

# Create a subscription plan in Razorpay dashboard first, then paste the plan ID:
# Dashboard → Products → Subscriptions → Plans → Create Plan
# Name: SecureScout Pro, Amount: ₹999, Period: monthly
RAZORPAY_PLAN_ID_PRO=plan_xxxxxxxxxxxxxxxx

# ── Email / SMTP (Optional — for report email delivery) ───────────────────────
# Gmail: Use App Password (not your regular password)
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
FROM_EMAIL=noreply@yourdomain.com

# ── Frontend URL (used in emails) ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000   # Change to https://yourdomain.com in prod

# ── CORS Origins (comma-separated JSON array) ─────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:80","https://yourdomain.com"]

# ── Allowed Hosts (production only) ───────────────────────────────────────────
ALLOWED_HOSTS=["localhost","127.0.0.1","yourdomain.com","www.yourdomain.com"]

# ── Scan Limits ───────────────────────────────────────────────────────────────
FREE_SCANS_PER_DAY=1
PRO_SCANS_PER_DAY=999
